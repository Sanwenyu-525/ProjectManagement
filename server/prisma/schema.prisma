generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== 用户 ====================

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  avatar       String?
  createdAt    DateTime @default(now())

  projects     Project[]
  integrations Integration[]
  tags         Tag[]

  @@map("users")
}

// ==================== 项目 ====================

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("Idea") // Idea/Planning/Development/Testing/Deployed/Maintained/Archived
  priority    String   @default("Medium") // Low/Medium/High/Critical
  source      String   @default("Local") // Local/Remote/Hybrid

  // 图标
  iconType  String @default("Auto") // Auto/Custom
  iconUrl   String?
  iconColor String?

  // 本地项目
  localPath    String?
  openCommand  String?

  // 线上信息
  liveUrl     String?
  domainName  String?
  techStack   String  @default("[]") // JSON 数组
  startDate   DateTime?
  targetDate  DateTime?

  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  remoteRepos  RemoteRepo[]
  tasks        Task[]
  milestones   Milestone[]
  documents    Document[]
  activityLogs ActivityLog[]
  tags         ProjectTag[]

  @@index([ownerId])
  @@index([status])
  @@map("projects")
}

// ==================== 远程仓库 ====================

model RemoteRepo {
  id             String   @id @default(uuid())
  projectId      String
  platform       String   // GitHub/GitLab/Gitee/Bitbucket
  repoUrl        String
  repoFullName   String   // 如 user/repo
  defaultBranch  String?
  repoStatus     String   @default("Synced") // Synced/Stale/Error/Disabled

  lastCommitSha String?
  lastCommitAt  DateTime?
  lastSyncAt    DateTime?
  extraConfig   String? // JSON

  integrationId String?
  integration   Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks Task[] @relation("RepoScope")

  @@index([projectId])
  @@index([platform])
  @@map("remote_repos")
}

// ==================== 任务 ====================

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("Todo") // Todo/InProgress/Done/Cancelled
  priority    String   @default("Medium") // Low/Medium/High/Critical
  dueDate     DateTime?

  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  repoScope  String? // 指向 RemoteRepo.id，NULL 表示所有仓库共享
  scopedRepo RemoteRepo? @relation("RepoScope", fields: [repoScope], references: [id], onDelete: SetNull)

  milestoneId String?
  milestone   Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  parentId String?
  parent   Task?   @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  children Task[]  @relation("SubTasks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([repoScope])
  @@map("tasks")
}

// ==================== 里程碑 ====================

model Milestone {
  id          String   @id @default(uuid())
  name        String
  description String?
  dueDate     DateTime?
  status      String   @default("Pending") // Pending/InProgress/Completed/Overdue

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks     Task[]

  @@index([projectId])
  @@map("milestones")
}

// ==================== 文档 ====================

model Document {
  id      String @id @default(uuid())
  title   String
  content String @default("")
  type    String @default("Doc") // Doc/Note/Changelog/Decision

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@map("documents")
}

// ==================== 第三方平台认证 ====================

model Integration {
  id           String   @id @default(uuid())
  platform     String   // GitHub/GitLab/Gitee
  accessToken  String   // 加密存储
  refreshToken String?
  config       String?  // JSON
  lastSyncAt   DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  remoteRepos RemoteRepo[]

  @@unique([userId, platform])
  @@map("integrations")
}

// ==================== 标签 ====================

model Tag {
  id     String @id @default(uuid())
  name   String
  color  String @default("#6366F1")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projects ProjectTag[]

  @@unique([userId, name])
  @@map("tags")
}

model ProjectTag {
  projectId String
  tagId     String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([projectId, tagId])
  @@map("project_tags")
}

// ==================== 活动日志 ====================

model ActivityLog {
  id         String   @id @default(uuid())
  action     String   // e.g. "status_change", "task_created", "repo_synced"
  entityType String   // Project/Task/Document/RemoteRepo
  entityId   String
  details    String?  // JSON
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
  @@map("activity_logs")
}
