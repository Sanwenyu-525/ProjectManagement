# 开发环境使用 SQLite
DATABASE_URL="file:./devhub.db"

# JWT
JWT_SECRET="devhub-dev-secret-change-in-production"
JWT_EXPIRES_IN="7d"

# 第三方平台
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITLAB_CLIENT_ID=""
GITLAB_CLIENT_SECRET=""
GITEE_CLIENT_ID=""
GITEE_CLIENT_SECRET=""

# 加密密钥（用于加密存储 Token）
ENCRYPTION_KEY="dev-encryption-key-32-chars-long!"

# 项目启动器
DEFAULT_OPEN_COMMAND="code ."

# 服务端口
PORT=3001
NODE_ENV="development"
